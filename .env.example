# Copy to secret.env (gitignored) for local runs; set the same vars in Coolify.
# Publisher credentials (used by the Pi's RTSP fallback push and SRT streamid).
# Keep alphanumeric: they end up inside URLs.
MTX_PUBLISH_USER=frogpublisher
MTX_PUBLISH_PASS=change-me-long-random
# SRT encryption passphrase, 10-64 chars (Pi ffmpeg caps at 64).
SRT_PASSPHRASE=change-me-10-to-64-chars
TZ=Europe/Berlin
