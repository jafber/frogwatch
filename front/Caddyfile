:80 {
	handle /healthz {
		respond "OK" 200
	}

	handle_path /stream/* {
		reverse_proxy mediamtx:8888 {
			flush_interval -1
			# mediamtx's cookie-check redirect points at /<path>/...;
			# re-add the /stream prefix it can't know about
			header_down Location ^/ /stream/
		}
	}

	handle_path /photos/* {
		root * /photos
		header Cache-Control "public, max-age=300"
		file_server
	}

	handle {
		root * /srv
		file_server
	}
}
